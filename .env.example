# Relay server port (default: 8788)
RELAY_PORT=8788

# Bind address (default: 0.0.0.0)
RELAY_BIND=0.0.0.0

# Relay URL for client mode (default: http://127.0.0.1:8788)
RELAY_URL=http://127.0.0.1:8788

# Bearer token for authentication (empty = open, no auth)
RELAY_TOKEN=

# Session name (auto-generated if not set)
RELAY_SESSION_NAME=

# Task TTL in hours (default: 8)
RELAY_TASK_TTL_HOURS=8
